---
// Social Proof Section
// ------------
// Description: A section with logos of social media platforms to enchance the trust of the users.

// Components
// - Layout
import Section from "../../ui/Section.astro"
import Row from "../../ui/Row.astro"
import Col from "../../ui/Col.astro"

// Content - Import SVGs as raw text to inline them (using Vite's ?raw query)
import unitedSvg from "../../../assets/logos/uhg.svg?raw"
import caesarsSvg from "../../../assets/logos/caesars.svg?raw"
import packupSvg from "../../../assets/logos/packup.svg?raw"
import simplyAgreeSvg from "../../../assets/logos/simplyagree.svg?raw"
import snackpassSvg from "../../../assets/logos/snackpass.svg?raw"
import wayupSvg from "../../../assets/logos/wayup.svg?raw"

const logos = [
  {
    svg: unitedSvg,
    alt: "United Healthgroup logo",
  },
  {
    svg: caesarsSvg,
    alt: "Caesars logo",
  },
  {
    svg: packupSvg,
    alt: "Packup logo",
  },
  {
    svg: simplyAgreeSvg,
    alt: "SimplyAgree logo",
  },
  {
    svg: snackpassSvg,
    alt: "Snackpass logo",
  },
  {
    svg: wayupSvg,
    alt: "WayUp logo",
  },
]

// Props
type Props = {
  classes?: string
}
const { classes } = Astro.props
---

<Section padding='bottom' classes={classes}>
  <Row>
    <Col span='12' align='center'>
      <h2 class='!mb-6 text-base font-normal text-muted-foreground'>
        Bringing expertise from our history working with Fortune 500 companies<br
        />
        and startups alike, now with a focus on the <strong class='text-primary'
          >local community.
        </strong>
      </h2>
    </Col>
  </Row>
  <Row flex classes='!flex-row'>
    {
      logos.map((item) => (
        <Col>
          <div set:html={item.svg} class='text-foreground p-4' />
        </Col>
      ))
    }
  </Row>
</Section>
