---
// Basic FAQ section
// ------------
// Description: A section that contains a list of frequently asked questions with answers.

// Components
// - Layout
import Section from "../../ui/Section.astro"
import Row from "../../ui/Row.astro"
import Col from "../../ui/Col.astro"
// - UI
import Accordion from "../../ui/Accordion.astro"
import Card from "../../ui/cards/partials/Card.astro"
import Button from "../../ui/button.astro"

// Data
import faqData from "../../../data/json-files/faqData.json"
const faqPricing = faqData.filter((faq) => faq.category === "pricing")

// Props
type Props = {
  classes?: string
}
const { classes } = Astro.props
---

<Section id='FAQ' classes={classes}>
  <Row>
    <Col span='12' align='center' classes='mb-12 max-w-4xl mx-auto space-y-8'>
      <h2 class='text-pretty font-heading text-4xl sm:text-5xl md:text-6xl'>
        <strong class='text-primary'>Simple</strong> pricing, no surprises
      </h2>
      <p class='text-lg leading-relaxed text-muted-foreground'>
        Any plan can be tailored to fit your needs and budget. We want to build
        a long-term relationship with you, and we're happy to work with you to
        find a plan that works best.
      </p>
    </Col>
    <Col span='2' />
    <Col span='8' classes='space-y-16'>
      <div>
        <Card classes='divide-y divide-zinc-100 dark:divide-zinc-800'>
          {
            faqPricing.map((faq: any) => (
              <Accordion title={faq.question} text={faq.reply} open={false} />
            ))
          }
        </Card>
      </div>
      <div class='text-center'>
        <div class='space-y-4'>
          <h3 class='text-3xl font-gotham uppercase'>Have more questions?</h3>

          <p class='text-lg leading-relaxed text-muted-foreground'>
            Visit our <a href='/faqs' class='text-primary underline'>FAQs</a> page
            for more questions, learn about our <a
              href='/services'
              class='text-primary underline'>Services</a
            > we offer, or get in touch with us directly.
          </p>
          <Button size='lg' type='link' href='/contact'>Get in touch</Button>
        </div>
      </div>
    </Col>
    <Col span='2' />
  </Row>
</Section>
