---
// Home page CTA Section
// ------------
// Description: A centered call to action section that contains: a title, text, a user review snippet, a button and a image.

// Components
// - Layout
import Section from "../../ui/Section.astro"
import Row from "../../ui/Row.astro"
import Col from "../../ui/Col.astro"
import { Image } from "astro:assets"
// - UI
import Button from "../../ui/button.astro"
import heroImage from "../../../assets/devices.png"
const date = new Date()
const nextMonth = new Date(date.getFullYear(), date.getMonth() + 1)
const monthAfterNext = new Date(date.getFullYear(), date.getMonth() + 2)
const monthRange = `${nextMonth.toLocaleString("default", { month: "long" })}-${monthAfterNext.toLocaleString("default", { month: "long" })}`
---

<Section id='intro' padding='top' classes='bg-zinc-50 dark:bg-zinc-900'>
  <Row>
    <Col span='2' />
    <Col span='8' align='center' classes='space-y-6'>
      <div
        class='font-gotham tracking-wide uppercase inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-muted text-sm'
      >
        <span class='relative flex size-3'>
          <span
            class='animate-ping absolute inline-flex h-full w-full rounded-full bg-light-emerald opacity-75'
          ></span>
          <span
            class='relative inline-flex rounded-full size-3 bg-light-emerald'
          ></span>
        </span> Now accepting new projects for {monthRange} 2026
      </div>
      <h1 class='font-heading text-4xl sm:text-5xl md:text-6xl'>
        <strong class='text-primary'>Modern</strong> Web & App Development for Southeastern
        Michigan Businesses
      </h1>

      <p class='text-lg text-muted-foreground'>
        Based in Manchester and Northville, we're your neighbors, and we're
        invested in your success. Let's be partners in building digital
        solutions that help your business thrive.
      </p>
      <Button size='lg' type='link' href='/contact'>Get Started</Button>
      <Button size='lg' type='link' href='/services' variant='outline'
        >Our Services</Button
      >
    </Col>
    <Col span='2' />
    <Col span='2' />
    <Col span='8'>
      <Image
        src={heroImage}
        alt='TODO: Add alt text'
        class='translate-y-8'
        format='webp'
      /></Col
    >
    <Col span='2' />
  </Row>
</Section>
