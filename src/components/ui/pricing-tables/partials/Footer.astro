---
// Pricing Footer
// ------------
// Description:  The footer area of the pricing table
// Properties:
// - classes: Additional classes to be added to the text field
// - type: The type of the pricing table (basic, featured)

// Props
type Props = {
  type?: "basic" | "featured"
  classes?: string
}
const { classes } = Astro.props
---

<footer
  class:list={[
    "pricing__footer border-t p-6 text-center text-sm border-zinc-100 bg-zinc-50/50 dark:border-zinc-800 dark:bg-zinc-800/50",
    { [`${classes}`]: classes },
  ]}
>
  <slot />
</footer>
