---
// Pricing Header
// ------------
// Description:  The header of the pricing table
// Properties:
// - classes: Additional classes to be added to the text field
// - type: The type of the pricing table (basic, featured)

// Props
type Props = {
  type?: "basic" | "featured"
  classes?: string
}

const { classes } = Astro.props
---

<header
  class:list={[
    "flex flex-col space-y-2 p-6 transition-all duration-300",
    { [`${classes}`]: classes },
  ]}
>
  <slot />
</header>
