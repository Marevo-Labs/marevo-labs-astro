---
// Components
// - Layout
import Layout from "../layouts/Layout.astro"
// - UI
import SidebarContent from "../components/blocks/basic/StickySidebar.astro"
import Hero from "../components/blocks/hero/PageHeader.astro"
import Button from "@/components/ui/button.astro"
import MeetTheTeam from "@/components/blocks/basic/MeetTheTeam.astro"
// Content
// - SEO
const SEO = {
  title: "Our Mission | Marevo Labs",
  description:
    "At Marevo Labs, our mission is to empower businesses with the tools and expertise they need to thrive in the digital age. We are dedicated to providing innovative solutions that drive growth, efficiency, and success.",
}
// - Page Header
const header = {
  title:
    "Empowering Businesses with <strong class='text-primary'>Modern Technology</strong>",
  text: "At Marevo Labs, our mission is to empower businesses with the tools and expertise they need to thrive in the digital age. We are dedicated to providing innovative solutions that drive growth, efficiency, and success.",
}
---

<Layout title={SEO.title} description={SEO.description}>
  <Hero title={header.title} text={header.text} />
  <SidebarContent>
    <div slot='sidebar'>
      <div class='space-y-4'>
        <h3 class='text-2xl font-gotham uppercase'>Our mission</h3>
      </div>
    </div>
    <div class='space-y-8'>
      <p class='text-lg leading-relaxed text-muted-foreground'>
        We believe that every business deserves access to modern technology,
        regardless of size or budget. Too many local businesses get left behind
        because they lack the resources or knowledge to build a strong digital
        presence. That's where we come in. We're not just developers—we're your
        neighbors, invested in the success of our community.
      </p>
      <p class='text-lg leading-relaxed text-muted-foreground'>
        Our approach is built on partnership and education. We take the time to
        understand your unique challenges and goals, then work alongside you to
        create solutions that truly fit your needs. We pride ourselves on clear
        communication, translating complex technical concepts into plain
        language, so you always know exactly what we're building and why it
        matters for your business.
      </p>

      <p class='text-lg leading-relaxed text-muted-foreground'>
        We started Marevo Labs because we saw too many local businesses
        struggling with outdated technology or no digital presence at all. We
        knew we could help. Our commitment to you is to level the playing
        field—bringing world-class development expertise to businesses right
        here in southeastern Michigan, from our hometowns of Manchester and
        Northville to neighboring communities like Ann Arbor, Plymouth, Canton,
        Saline, Dexter, Chelsea, and beyond.
      </p>
      <p>
        <Button size='lg' type='link' href='/about'>Read more about us</Button>
      </p>
    </div>
  </SidebarContent>
  <MeetTheTeam />
</Layout>
