---
// Components
// - Layout
import Layout from "../layouts/Layout.astro"
// - UI
import FormHero from "../components/blocks/hero/ContactHero.astro"
import CTA from "../components/blocks/CTA/BasicDark.astro"
import ContactCards from "../components/blocks/contact/ContactCards.astro"
import SocialProof from "../components/blocks/socialproof/Basic.astro"

// Content
// - SEO
const SEO = {
  title: "Contact Us | Marevo Labs",
  description:
    "Have questions or need assistance? Contact Marevo Labs today for support, inquiries, or feedback. Our team is here to help you make the most of your Marevo Labs experience.",
}
// - Page Header
const header = {
  title: "Get in touch with us <strong class='text-primary'>today</strong>.",
  text: "Fill out the form and let us know about your project. We typically respond to everyone within 24 hours of contacting us.",
}
---

<Layout title={SEO.title} description={SEO.description}>
  <FormHero
    title={header.title}
    text={header.text}
    id='contact'
    classes='bg-zinc-50 dark:bg-zinc-950/80'
  />
  <ContactCards classes='dark:bg-zinc-950/80' />
  <SocialProof classes='dark:bg-zinc-950/80' />
  <CTA />
</Layout>
