---
// Components
// - Layout
import Layout from "../layouts/Layout.astro"
// - UI
import Feature from "../components/blocks/features/FeatureSticky.astro"
import Hero from "../components/blocks/hero/PageHeader.astro"
import CTA from "../components/blocks/CTA/BasicDark.astro"

// Data
import featuresData from "../data/json-files/featuresData.json"
// - Feature Categories
const featuresWebDesign = featuresData.filter(
  (feature) => feature.category === "WebDesign"
)
const featuresProductivity = featuresData.filter(
  (feature) => feature.category === "Productivity"
)
const featuresSecurity = featuresData.filter(
  (feature) => feature.category === "Security"
)
const featuresIntegrations = featuresData.filter(
  (feature) => feature.category === "Integrations"
)
const featuresSupport = featuresData.filter(
  (feature) => feature.category === "Support"
)

// Content
// - SEO
const SEO = {
  title: "Services | Marevo Labs",
  description:
    "Explore our powerful features designed to enhance productivity, ensure top-notch security, and integrate seamlessly with your favorite tools. Join thousands of satisfied users and transform your workflow with Marevo Labs today!",
}
// - Page Header
const header = {
  title:
    "<strong class='text-primary'>Professional</strong> Web Design & Development Services",
  text: "At Marevo Labs, we bring a wealth of knowledge and expertise to every project. We don't just build websites, we build solutions that help your business thrive.",
}
---

<Layout title={SEO.title} description={SEO.description}>
  <Hero title={header.title} text={header.text} />
  <Feature
    title='Web Design & Development'
    text='From simple static sites to complex web applications, we build websites that look great and work even better.'
    data={featuresWebDesign}
  />
  <Feature
    title='Custom App Development'
    text="We build custom apps that are tailored to your business needs. Whether you need a simple app to manage your inventory or a complex app to manage your entire business, we've got you covered."
    data={featuresSecurity}
    classes='bg-zinc-50 dark:bg-zinc-900'
  />
  <Feature
    title='UX/UI Design'
    text='We design user interfaces that are not only beautiful but also easy to use.'
    data={featuresProductivity}
  />
  <Feature
    title='SEO & Other Services'
    text='We offer a variety of SEO and other services to help you get more traffic and more customers.'
    data={featuresIntegrations}
    classes='bg-zinc-50 dark:bg-zinc-900'
  />
  <Feature
    title='24/7 Expert Help'
    text='We offer 24/7 expert support to help you with any questions or issues you may have.'
    data={featuresSupport}
  />
  <CTA />
</Layout>
